{
  "expo": {
    "name": "Pixnap",
    "slug": "pixnap",
    "version": "1.4.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "pixnap",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0e1117"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Pixnap needs camera access to scan documents.",
        "NSPhotoLibraryUsageDescription": "Pixnap needs photo library access to select images for scanning.",
        "NSPhotoLibraryAddUsageDescription": "Pixnap needs access to save scanned images to your photo library."
      },
      "bundleIdentifier": "me.pixnap",
      "buildNumber": "18",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0e1117"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "WRITE_EXTERNAL_STORAGE",
        "READ_EXTERNAL_STORAGE",
        "com.google.android.gms.permission.AD_ID"
      ],
      "package": "me.pixnap",
      "versionCode": 12
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "react-native-document-scanner-plugin",
        {
          "cameraPermission": "Pixnap needs camera access to scan documents."
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-6262791337263815~4072677450",
          "iosAppId": "ca-app-pub-6262791337263815~9846555378"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Pixnap needs photo library access to save scanned images.",
          "savePhotosPermission": "Pixnap needs photo library access to save scanned images."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d7e9fdb2-d8d1-4383-8028-3e8518b288a0"
      }
    },
    "owner": "binzhu"
  }
}

{
  "expo": {
    "name": "Pixnap",
    "slug": "pixnap",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "pixnap",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0e1117"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "需要相机权限来拍摄票据",
        "NSPhotoLibraryUsageDescription": "需要相册权限来选择票据图片",
        "NSPhotoLibraryAddUsageDescription": "需要相册权限来保存扫描的图片",
        "NSUserTrackingUsageDescription": "This allows Pixnap to show you relevant ads."
      },
      "bundleIdentifier": "me.pixnap",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0e1117"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "WRITE_EXTERNAL_STORAGE",
        "READ_EXTERNAL_STORAGE",
        "com.google.android.gms.permission.AD_ID"
      ],
      "package": "me.pixnap",
      "versionCode": 3
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "react-native-document-scanner-plugin",
        {
          "cameraPermission": "需要相机权限来扫描文档"
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-6262791337263815~4072677450",
          "iosAppId": "ca-app-pub-6262791337263815~9846555378"
        }
      ],
      "expo-tracking-transparency",
      [
        "expo-media-library",
        {
          "photosPermission": "需要相册权限来保存扫描的图片",
          "savePhotosPermission": "需要相册权限来保存扫描的图片"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d7e9fdb2-d8d1-4383-8028-3e8518b288a0"
      }
    },
    "owner": "binzhu"
  }
}
